# Copy to .env on the server (same directory as docker-compose.yml):
#   cp .env.example .env
# Then set JWT_SK to a long random string.

# MongoDB (compose service name: mongo)
MONGO_URI=mongodb://mongo:27017/party-spies

# API signing (required)
JWT_SK=change-me-to-a-long-random-secret

# Optional: host port mapped to the frontend nginx container (default 80)
# HTTP_PORT=80
