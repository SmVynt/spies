# Copy to .env on the server (same directory as docker-compose.yml):
#   cp .env.example .env
# Then set JWT_SK to a long random string.

# MongoDB (compose service name: mongo)
MONGO_URI=mongodb://mongo:27017/party-spies

# API signing (required)
JWT_SK=change-me-to-a-long-random-secret

# Optional: host port mapped to the frontend nginx container (default 80)
# HTTP_PORT=80

# Mongo Express — web UI for MongoDB (bound to 127.0.0.1:8081 by default; use SSH tunnel on VPS)
ME_USERNAME=mongo-express-user
ME_PASSWORD=change-me-strong-mongo-express-password
# MONGO_EXPRESS_BIND=127.0.0.1
# MONGO_EXPRESS_PORT=8081

# Optional: mongo dumps from scripts/backup-mongo.sh (cron)
# BACKUP_DIR=/opt/spies/backups
# BACKUP_RETENTION_DAYS=14
# MONGO_BACKUP_DATABASE=party-spies
